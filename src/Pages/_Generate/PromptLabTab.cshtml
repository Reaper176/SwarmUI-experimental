@model GeneratePageModel

<div class="prompt-lab-wrapper">
    <div class="prompt-lab-column prompt-lab-library">
        <div class="prompt-lab-toolbar">
            <button class="basic-button translate" onclick="promptLab.newPrompt()">New</button>
            <button class="basic-button translate" onclick="promptLab.savePrompt()">Save</button>
            <button class="basic-button translate" onclick="promptLab.duplicatePrompt()">Duplicate</button>
            <button class="basic-button translate" onclick="promptLab.deletePrompt()">Delete</button>
        </div>
        <input class="auto-text prompt-lab-search" id="prompt_lab_search" placeholder="Search prompts" oninput="promptLab.renderPromptList()" />
        <div id="prompt_lab_prompt_list" class="prompt-lab-list"></div>
    </div>
    <div class="prompt-lab-column prompt-lab-editor">
        <input class="auto-text prompt-lab-title" id="prompt_lab_name" placeholder="Prompt name" />
        <textarea class="auto-text prompt-lab-textarea" id="prompt_lab_positive" placeholder="Positive prompt" oninput="promptLab.refreshPreview()"></textarea>
        <textarea class="auto-text prompt-lab-textarea" id="prompt_lab_negative" placeholder="Negative prompt" oninput="promptLab.refreshPreview()"></textarea>
        <input class="auto-text" id="prompt_lab_tags" placeholder="Tags, comma-separated" />
        <textarea class="auto-text prompt-lab-notes" id="prompt_lab_notes" placeholder="Notes"></textarea>
    </div>
    <div class="prompt-lab-column prompt-lab-preview">
        <div class="prompt-lab-toolbar">
            <button class="basic-button translate" onclick="promptLab.sendToGenerate()">Send to Generate</button>
            <button class="basic-button translate" onclick="promptLab.previewWildcards()">Preview Wildcards</button>
        </div>
        <div class="prompt-lab-section-title translate">Detected Wildcards</div>
        <div id="prompt_lab_wildcards" class="prompt-lab-output"></div>
        <div class="prompt-lab-section-title translate">Preview</div>
        <div id="prompt_lab_preview" class="prompt-lab-output"></div>
        <div class="prompt-lab-section-title translate">Warnings</div>
        <div id="prompt_lab_warnings" class="prompt-lab-output"></div>
    </div>
</div>
