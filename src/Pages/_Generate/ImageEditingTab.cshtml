                            <select class="auto-dropdown" id="imageediting_effect_preset_select" style="width:100%;">
                                <option value="neutral">Neutral</option>
                                <option value="cinematic-warm">Cinematic Warm</option>
                                <option value="teal-orange">Teal &amp; Orange</option>
                                <option value="cool-fade">Cool Fade</option>
                                <option value="noir">Noir</option>
                                <option value="vintage-fade">Vintage Fade</option>
                            </select>
                            <div class="imageediting_layer_option_row imageediting_layer_option_row_spaced">
                                <label class="translate" for="imageediting_artistic_filter_select">Artistic Filter</label>
