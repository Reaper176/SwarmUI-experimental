@model GeneratePageModel

<div class="imageediting_layout" style="line-height:1.5">
    <div class="imageediting_sidebar imageediting_sidebar_left" id="imageediting_input_sidebar">
        <ul class="nav nav-tabs" role="tablist" id="imageediting_inputsidebartabcollection">
            <li class="nav-item" role="presentation">
                <a class="nav-link active translate" data-bs-toggle="tab" href="#Image-Editing-Inputs-Tab" aria-selected="true" role="tab">Inputs</a>
            </li>
        </ul>
        <div class="tab-content" id="imageediting_inputsidebartab_content">
            <div class="tab-pane show active genpage-bottom-tab" id="Image-Editing-Inputs-Tab" role="tabpanel">
                <span class="interrupt_line"></span>
                <div class="main_inputs_area_wrapper" id="imageediting_main_inputs_area_wrapper">
                    <div class="imageediting_input_group">
                        <div class="imageediting_section_header" id="imageediting_tools_header" onclick="imageEditingToggleInputSection('tools')">
                            <span class="imageediting_section_header_title translate">Editor Tools</span>
                            <span class="imageediting_section_header_state" id="imageediting_tools_toggle_state">-</span>
                        </div>
                        <div class="imageediting_buttons_grid" id="imageediting_tool_buttons"></div>
                    </div>
                    <div class="imageediting_input_group">
                        <div class="imageediting_section_header" id="imageediting_actions_header" onclick="imageEditingToggleInputSection('actions')">
                            <span class="imageediting_section_header_title translate">Editor Actions</span>
                            <span class="imageediting_section_header_state" id="imageediting_actions_toggle_state">-</span>
                        </div>
                        <div class="imageediting_buttons_grid" id="imageediting_option_buttons"></div>
                    </div>
                    <div class="imageediting_input_group">
                        <div class="imageediting_section_header" id="imageediting_layer_options_header" onclick="imageEditingToggleInputSection('layer_options')">
                            <span class="imageediting_section_header_title translate">Layer Options</span>
                            <span class="imageediting_section_header_state" id="imageediting_layer_options_toggle_state">-</span>
                        </div>
                        <div class="imageediting_layer_options_body" id="imageediting_layer_options_body">
                            <div class="imageediting_layer_option_row">
                                <label class="translate" for="imageediting_layer_opacity_slider">Layer Transparency</label>
                                <span id="imageediting_layer_opacity_value">100%</span>
                            </div>
                            <div class="auto-slider-range-wrapper">
                                <input type="range" class="auto-slider-range" id="imageediting_layer_opacity_slider" min="0" max="100" step="1" value="100" oninput="updateRangeStyle(this)" onchange="updateRangeStyle(this)">
                            </div>
                            <div class="imageediting_layer_option_context" id="imageediting_layer_opacity_context">Active Layer: Image</div>
                            <div class="imageediting_layer_option_row imageediting_layer_option_row_spaced">
                                <label class="translate" for="imageediting_layer_blend_mode_select">Blend Mode</label>
                            </div>
                            <select class="auto-dropdown" id="imageediting_layer_blend_mode_select" style="width:100%;">
                                <option value="source-over">Normal</option>
                                <option value="multiply">Multiply</option>
                                <option value="screen">Screen</option>
                                <option value="overlay">Overlay</option>
                                <option value="darken">Darken</option>
                                <option value="lighten">Lighten</option>
                                <option value="color-dodge">Color Dodge</option>
                                <option value="color-burn">Color Burn</option>
                                <option value="soft-light">Soft Light</option>
                                <option value="hard-light">Hard Light</option>
                                <option value="hue">Hue</option>
                                <option value="saturation">Saturation</option>
                                <option value="color">Color</option>
                                <option value="luminosity">Luminosity</option>
                            </select>
                            <div class="imageediting_layer_option_context" id="imageediting_layer_blend_mode_context">Active Layer: Image</div>
                            <div class="imageediting_buttons_grid imageediting_layer_option_buttons" id="imageediting_layer_option_buttons">
                                <button type="button" class="basic-button imageediting_option_button translate" id="imageediting_layer_delete_button">Delete Layer</button>
                                <button type="button" class="basic-button imageediting_option_button translate" id="imageediting_layer_duplicate_button">Duplicate Layer</button>
                                <button type="button" class="basic-button imageediting_option_button translate" id="imageediting_layer_convert_to_image_button">Convert To Image Layer</button>
                                <button type="button" class="basic-button imageediting_option_button translate" id="imageediting_layer_invert_mask_button">Invert Mask</button>
                                <button type="button" class="basic-button imageediting_option_button translate" id="imageediting_layer_convert_to_mask_button">Convert To Mask Layer</button>
                                <button type="button" class="basic-button imageediting_option_button translate" id="imageediting_layer_invert_colors_button">Invert Colors</button>
                                <button type="button" class="basic-button imageediting_option_button translate" id="imageediting_layer_flip_mirror_horizontal_button">Flip / Mirror Horizontal</button>
                                <button type="button" class="basic-button imageediting_option_button translate" id="imageediting_layer_flip_mirror_vertical_button">Flip / Mirror Vertical</button>
                            </div>
                        </div>
                    </div>
                    <div class="imageediting_input_group">
                        <div class="imageediting_section_header" id="imageediting_image_options_header" onclick="imageEditingToggleInputSection('image_options')">
                            <span class="imageediting_section_header_title translate">Image Options</span>
                            <span class="imageediting_section_header_state" id="imageediting_image_options_toggle_state">-</span>
                        </div>
                        <div class="imageediting_layer_options_body" id="imageediting_image_options_body">
                            <div class="imageediting_layer_option_row">
                                <label class="translate" for="imageediting_layer_saturation_slider">Saturation</label>
                                <span id="imageediting_layer_saturation_value">100%</span>
                            </div>
                            <div class="auto-slider-range-wrapper">
                                <input type="range" class="auto-slider-range" id="imageediting_layer_saturation_slider" min="0" max="200" step="1" value="100" oninput="updateRangeStyle(this)" onchange="updateRangeStyle(this)">
                            </div>
                            <div class="imageediting_layer_option_context" id="imageediting_layer_saturation_context">Active Layer: Image</div>
                            <div class="imageediting_layer_option_row imageediting_layer_option_row_spaced">
                                <label class="translate" for="imageediting_layer_light_value_slider">Brightness / Exposure</label>
                                <span id="imageediting_layer_light_value_value">100%</span>
                            </div>
                            <div class="auto-slider-range-wrapper">
                                <input type="range" class="auto-slider-range" id="imageediting_layer_light_value_slider" min="0" max="200" step="1" value="100" oninput="updateRangeStyle(this)" onchange="updateRangeStyle(this)">
                            </div>
                            <div class="imageediting_layer_option_context" id="imageediting_layer_light_value_context">Active Layer: Image</div>
                            <div class="imageediting_layer_option_row imageediting_layer_option_row_spaced">
                                <label class="translate" for="imageediting_layer_contrast_slider">Contrast</label>
                                <span id="imageediting_layer_contrast_value">100%</span>
                            </div>
                            <div class="auto-slider-range-wrapper">
                                <input type="range" class="auto-slider-range" id="imageediting_layer_contrast_slider" min="0" max="200" step="1" value="100" oninput="updateRangeStyle(this)" onchange="updateRangeStyle(this)">
                            </div>
                            <div class="imageediting_layer_option_row imageediting_layer_option_row_spaced">
                                <label class="translate" for="imageediting_layer_hue_shift_slider">Hue Shift</label>
                                <span id="imageediting_layer_hue_shift_value">0&deg;</span>
                            </div>
                            <div class="auto-slider-range-wrapper">
                                <input type="range" class="auto-slider-range" id="imageediting_layer_hue_shift_slider" min="-180" max="180" step="1" value="0" oninput="updateRangeStyle(this)" onchange="updateRangeStyle(this)">
                            </div>
                            <div class="imageediting_layer_option_row imageediting_layer_option_row_spaced">
                                <label class="translate" for="imageediting_layer_gamma_slider">Gamma</label>
                                <span id="imageediting_layer_gamma_value">1.00</span>
                            </div>
                            <div class="auto-slider-range-wrapper">
                                <input type="range" class="auto-slider-range" id="imageediting_layer_gamma_slider" min="10" max="300" step="1" value="100" oninput="updateRangeStyle(this)" onchange="updateRangeStyle(this)">
                            </div>
                            <div class="imageediting_layer_option_row imageediting_layer_option_row_spaced">
                                <label class="translate" for="imageediting_layer_temperature_slider">Temperature</label>
                                <span id="imageediting_layer_temperature_value">0%</span>
                            </div>
                            <div class="auto-slider-range-wrapper">
                                <input type="range" class="auto-slider-range" id="imageediting_layer_temperature_slider" min="-100" max="100" step="1" value="0" oninput="updateRangeStyle(this)" onchange="updateRangeStyle(this)">
                            </div>
                            <div class="imageediting_layer_option_row imageediting_layer_option_row_spaced">
                                <label class="translate" for="imageediting_layer_tint_slider">Tint</label>
                                <span id="imageediting_layer_tint_value">0%</span>
                            </div>
                            <div class="auto-slider-range-wrapper">
                                <input type="range" class="auto-slider-range" id="imageediting_layer_tint_slider" min="-100" max="100" step="1" value="0" oninput="updateRangeStyle(this)" onchange="updateRangeStyle(this)">
                            </div>
                            <div class="imageediting_layer_option_row imageediting_layer_option_row_spaced">
                                <label class="translate" for="imageediting_layer_shadows_slider">Shadows</label>
                                <span id="imageediting_layer_shadows_value">0%</span>
                            </div>
                            <div class="auto-slider-range-wrapper">
                                <input type="range" class="auto-slider-range" id="imageediting_layer_shadows_slider" min="-100" max="100" step="1" value="0" oninput="updateRangeStyle(this)" onchange="updateRangeStyle(this)">
                            </div>
                            <div class="imageediting_layer_option_row imageediting_layer_option_row_spaced">
                                <label class="translate" for="imageediting_layer_highlights_slider">Highlights</label>
                                <span id="imageediting_layer_highlights_value">0%</span>
                            </div>
                            <div class="auto-slider-range-wrapper">
                                <input type="range" class="auto-slider-range" id="imageediting_layer_highlights_slider" min="-100" max="100" step="1" value="0" oninput="updateRangeStyle(this)" onchange="updateRangeStyle(this)">
                            </div>
                            <div class="imageediting_layer_option_row imageediting_layer_option_row_spaced">
                                <label class="translate" for="imageediting_layer_whites_slider">Whites</label>
                                <span id="imageediting_layer_whites_value">0%</span>
                            </div>
                            <div class="auto-slider-range-wrapper">
                                <input type="range" class="auto-slider-range" id="imageediting_layer_whites_slider" min="-100" max="100" step="1" value="0" oninput="updateRangeStyle(this)" onchange="updateRangeStyle(this)">
                            </div>
                            <div class="imageediting_layer_option_row imageediting_layer_option_row_spaced">
                                <label class="translate" for="imageediting_layer_blacks_slider">Blacks</label>
                                <span id="imageediting_layer_blacks_value">0%</span>
                            </div>
                            <div class="auto-slider-range-wrapper">
                                <input type="range" class="auto-slider-range" id="imageediting_layer_blacks_slider" min="-100" max="100" step="1" value="0" oninput="updateRangeStyle(this)" onchange="updateRangeStyle(this)">
                            </div>
                            <div class="imageediting_tone_balance_group">
                                <div class="imageediting_tone_balance_title translate"><b>Color Balance (RGB)</b></div>
                                <div class="imageediting_tone_balance_section">
                                    <div class="imageediting_tone_balance_section_title translate">Shadows</div>
                                    <div class="imageediting_layer_option_row">
                                        <label for="imageediting_tone_shadows_r_slider">R</label>
                                        <span id="imageediting_tone_shadows_r_value">0%</span>
                                    </div>
                                    <div class="auto-slider-range-wrapper">
                                        <input type="range" class="auto-slider-range imageediting_tone_balance_slider" id="imageediting_tone_shadows_r_slider" data-range="shadows" data-channel="r" min="-100" max="100" step="1" value="0" oninput="updateRangeStyle(this)" onchange="updateRangeStyle(this)">
                                    </div>
                                    <div class="imageediting_layer_option_row">
                                        <label for="imageediting_tone_shadows_g_slider">G</label>
                                        <span id="imageediting_tone_shadows_g_value">0%</span>
                                    </div>
                                    <div class="auto-slider-range-wrapper">
                                        <input type="range" class="auto-slider-range imageediting_tone_balance_slider" id="imageediting_tone_shadows_g_slider" data-range="shadows" data-channel="g" min="-100" max="100" step="1" value="0" oninput="updateRangeStyle(this)" onchange="updateRangeStyle(this)">
                                    </div>
                                    <div class="imageediting_layer_option_row">
                                        <label for="imageediting_tone_shadows_b_slider">B</label>
                                        <span id="imageediting_tone_shadows_b_value">0%</span>
                                    </div>
                                    <div class="auto-slider-range-wrapper">
                                        <input type="range" class="auto-slider-range imageediting_tone_balance_slider" id="imageediting_tone_shadows_b_slider" data-range="shadows" data-channel="b" min="-100" max="100" step="1" value="0" oninput="updateRangeStyle(this)" onchange="updateRangeStyle(this)">
                                    </div>
                                </div>
                                <div class="imageediting_tone_balance_section">
                                    <div class="imageediting_tone_balance_section_title translate">Midtones</div>
                                    <div class="imageediting_layer_option_row">
                                        <label for="imageediting_tone_midtones_r_slider">R</label>
                                        <span id="imageediting_tone_midtones_r_value">0%</span>
                                    </div>
                                    <div class="auto-slider-range-wrapper">
                                        <input type="range" class="auto-slider-range imageediting_tone_balance_slider" id="imageediting_tone_midtones_r_slider" data-range="midtones" data-channel="r" min="-100" max="100" step="1" value="0" oninput="updateRangeStyle(this)" onchange="updateRangeStyle(this)">
                                    </div>
                                    <div class="imageediting_layer_option_row">
                                        <label for="imageediting_tone_midtones_g_slider">G</label>
                                        <span id="imageediting_tone_midtones_g_value">0%</span>
                                    </div>
                                    <div class="auto-slider-range-wrapper">
                                        <input type="range" class="auto-slider-range imageediting_tone_balance_slider" id="imageediting_tone_midtones_g_slider" data-range="midtones" data-channel="g" min="-100" max="100" step="1" value="0" oninput="updateRangeStyle(this)" onchange="updateRangeStyle(this)">
                                    </div>
                                    <div class="imageediting_layer_option_row">
                                        <label for="imageediting_tone_midtones_b_slider">B</label>
                                        <span id="imageediting_tone_midtones_b_value">0%</span>
                                    </div>
                                    <div class="auto-slider-range-wrapper">
                                        <input type="range" class="auto-slider-range imageediting_tone_balance_slider" id="imageediting_tone_midtones_b_slider" data-range="midtones" data-channel="b" min="-100" max="100" step="1" value="0" oninput="updateRangeStyle(this)" onchange="updateRangeStyle(this)">
                                    </div>
                                </div>
                                <div class="imageediting_tone_balance_section">
                                    <div class="imageediting_tone_balance_section_title translate">Highlights</div>
                                    <div class="imageediting_layer_option_row">
                                        <label for="imageediting_tone_highlights_r_slider">R</label>
                                        <span id="imageediting_tone_highlights_r_value">0%</span>
                                    </div>
                                    <div class="auto-slider-range-wrapper">
                                        <input type="range" class="auto-slider-range imageediting_tone_balance_slider" id="imageediting_tone_highlights_r_slider" data-range="highlights" data-channel="r" min="-100" max="100" step="1" value="0" oninput="updateRangeStyle(this)" onchange="updateRangeStyle(this)">
                                    </div>
                                    <div class="imageediting_layer_option_row">
                                        <label for="imageediting_tone_highlights_g_slider">G</label>
                                        <span id="imageediting_tone_highlights_g_value">0%</span>
                                    </div>
                                    <div class="auto-slider-range-wrapper">
                                        <input type="range" class="auto-slider-range imageediting_tone_balance_slider" id="imageediting_tone_highlights_g_slider" data-range="highlights" data-channel="g" min="-100" max="100" step="1" value="0" oninput="updateRangeStyle(this)" onchange="updateRangeStyle(this)">
                                    </div>
                                    <div class="imageediting_layer_option_row">
                                        <label for="imageediting_tone_highlights_b_slider">B</label>
                                        <span id="imageediting_tone_highlights_b_value">0%</span>
                                    </div>
                                    <div class="auto-slider-range-wrapper">
                                        <input type="range" class="auto-slider-range imageediting_tone_balance_slider" id="imageediting_tone_highlights_b_slider" data-range="highlights" data-channel="b" min="-100" max="100" step="1" value="0" oninput="updateRangeStyle(this)" onchange="updateRangeStyle(this)">
                                    </div>
                                </div>
                                <div class="imageediting_layer_option_context" id="imageediting_tone_balance_context">Active Layer: Image</div>
                            </div>
                        </div>
                    </div>
                    <div class="imageediting_input_group">
                        <div class="imageediting_section_header" id="imageediting_selection_crop_header" onclick="imageEditingToggleInputSection('selection_crop')">
                            <span class="imageediting_section_header_title translate">Selection / Crop</span>
                            <span class="imageediting_section_header_state" id="imageediting_selection_crop_toggle_state">-</span>
                        </div>
                        <div class="imageediting_layer_options_body" id="imageediting_selection_crop_body">
                            <div class="imageediting_buttons_grid" id="imageediting_selection_tool_buttons"></div>
                            <div class="imageediting_buttons_grid imageediting_layer_option_buttons">
                                <button type="button" class="basic-button imageediting_option_button translate" id="imageediting_clear_selection_button">Clear Selection</button>
                            </div>
                            <div class="imageediting_layer_option_row imageediting_layer_option_row_spaced">
                                <label class="translate" for="imageediting_selection_mode_select">Selection Mode</label>
                            </div>
                            <select class="auto-dropdown" id="imageediting_selection_mode_select" style="width:100%;">
                                <option value="replace">Replace</option>
                                <option value="add">Add</option>
                                <option value="subtract">Subtract</option>
                                <option value="intersect">Intersect</option>
                            </select>
                            <div class="imageediting_layer_option_row imageediting_layer_option_row_spaced">
                                <label class="translate" for="imageediting_selection_tolerance_slider">Tolerance</label>
                                <span id="imageediting_selection_tolerance_value">32</span>
                            </div>
                            <div class="auto-slider-range-wrapper">
                                <input type="range" class="auto-slider-range" id="imageediting_selection_tolerance_slider" min="0" max="128" step="1" value="32" oninput="updateRangeStyle(this)" onchange="updateRangeStyle(this)">
                            </div>
                            <div class="imageediting_layer_option_row imageediting_layer_option_row_spaced">
                                <label class="translate" for="imageediting_selection_sample_source_select">Sample Source</label>
                            </div>
                            <select class="auto-dropdown" id="imageediting_selection_sample_source_select" style="width:100%;">
                                <option value="composite">Composite</option>
                                <option value="layer">Current Layer</option>
                            </select>
                            <div class="imageediting_layer_option_row imageediting_layer_option_row_spaced">
                                <label class="translate" for="imageediting_selection_contiguous_toggle">Contiguous</label>
                                <input type="checkbox" id="imageediting_selection_contiguous_toggle" checked>
                            </div>
                            <div class="imageediting_layer_option_row imageediting_layer_option_row_spaced">
                                <label class="translate" for="imageediting_selection_feather_slider">Feather</label>
                                <span id="imageediting_selection_feather_value">0px</span>
                            </div>
                            <div class="auto-slider-range-wrapper">
                                <input type="range" class="auto-slider-range" id="imageediting_selection_feather_slider" min="0" max="32" step="1" value="0" oninput="updateRangeStyle(this)" onchange="updateRangeStyle(this)">
                            </div>
                            <div class="imageediting_layer_option_row imageediting_layer_option_row_spaced">
                                <label class="translate" for="imageediting_selection_expand_slider">Expand</label>
                                <span id="imageediting_selection_expand_value">0px</span>
                            </div>
                            <div class="auto-slider-range-wrapper">
                                <input type="range" class="auto-slider-range" id="imageediting_selection_expand_slider" min="0" max="32" step="1" value="0" oninput="updateRangeStyle(this)" onchange="updateRangeStyle(this)">
                            </div>
                            <div class="imageediting_layer_option_row imageediting_layer_option_row_spaced">
                                <label class="translate" for="imageediting_selection_smooth_slider">Smooth</label>
                                <span id="imageediting_selection_smooth_value">0</span>
                            </div>
                            <div class="auto-slider-range-wrapper">
                                <input type="range" class="auto-slider-range" id="imageediting_selection_smooth_slider" min="0" max="6" step="1" value="0" oninput="updateRangeStyle(this)" onchange="updateRangeStyle(this)">
                            </div>
                            <div class="imageediting_layer_option_row imageediting_layer_option_row_spaced">
                                <label class="translate" for="imageediting_crop_display_width">Display Size</label>
                            </div>
                            <div class="imageediting_crop_size_inputs">
                                <input type="number" class="auto-number" id="imageediting_crop_display_width" min="1" step="1" value="512">
                                <input type="number" class="auto-number" id="imageediting_crop_display_height" min="1" step="1" value="512">
                            </div>
                            <div class="imageediting_buttons_grid imageediting_layer_option_buttons">
                                <button type="button" class="basic-button imageediting_option_button translate" id="imageediting_crop_commit_button">Commit Crop</button>
                                <button type="button" class="basic-button imageediting_option_button translate" id="imageediting_crop_cancel_button">Cancel Crop</button>
                                <button type="button" class="basic-button imageediting_option_button translate" id="imageediting_crop_reset_button">Reset Crop</button>
                            </div>
                        </div>
                    </div>
                    <div class="imageediting_input_group">
                        <div class="imageediting_section_header" id="imageediting_effects_presets_header" onclick="imageEditingToggleInputSection('effects_presets')">
                            <span class="imageediting_section_header_title translate">Effects / Presets</span>
                            <span class="imageediting_section_header_state" id="imageediting_effects_presets_toggle_state">-</span>
                        </div>
                        <div class="imageediting_layer_options_body" id="imageediting_effects_presets_body">
                            <div class="imageediting_buttons_grid imageediting_layer_option_buttons">
                                <button type="button" class="basic-button imageediting_option_button translate" id="imageediting_new_adjustment_layer_button">New Adjustment Layer</button>
                                <button type="button" class="basic-button imageediting_option_button translate" id="imageediting_edit_adjustment_mask_button">Edit Adjustment Mask</button>
                                <button type="button" class="basic-button imageediting_option_button translate" id="imageediting_toggle_adjustment_mask_button">Hide Adjustment Mask</button>
                            </div>
                            <div class="imageediting_layer_option_row imageediting_layer_option_row_spaced">
                                <label class="translate" for="imageediting_effect_preset_select">Color Grading Preset</label>
